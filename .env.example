# ── API Keys ──────────────────────────────────────────────────────────────────
# Google Maps API key (required for real traffic scores)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# Anthropic Claude API key (required for AI-generated reports)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Claude Model ──────────────────────────────────────────────────────────────
# Options: claude-opus-4-5, claude-3-7-sonnet-20250219, claude-3-5-haiku-20241022
CLAUDE_MODEL=claude-opus-4-5

# ── App Settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
